# .env example for backend

# Local SQLite database (used by Prisma for dev)
DATABASE_URL="file:./dev.db"

# MongoDB Atlas Connection String
# Format: mongodb://username:password@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=REPLICA_SET_NAME
# Or: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
#
# To get your connection string:
# 1. Go to MongoDB Atlas Dashboard > Clusters
# 2. Click "Connect" on your cluster
# 3. Choose "Drivers" > "Node.js"
# 4. Copy the "Legacy URI String" (recommended for broader compatibility)
# 5. Replace <db_password> with your actual database user password
#
# IMPORTANT: If you get "bad auth : authentication failed":
#   - Verify the password matches exactly in MongoDB Atlas > Database Access > Edit User
#   - If unsure, regenerate the password and copy the full connection string again
#   - Ensure your IP is whitelisted: MongoDB Atlas > Network Access > Add IP Address
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?appName=YourAppName"

# JWT Secrets (use strong random values in production!)
JWT_PRIVATE_KEY="supersecret"
JWT_PUBLIC_KEY="supersecret"

# Server Port
PORT=3000
